{
  "openapi": "3.1.0",
  "info": {
    "title": "GoBuy 商城 API",
    "description": "RESTful API 设计 - 已修正动词路径问题",
    "version": "1.0.0"
  },
  "paths": {
    "/api/v1/sessions": {
      "post": {
        "summary": "创建用户会话（登录）",
        "description": "用户通过账号密码进行登录认证，登录成功后返回 JWT Token",
        "tags": ["认证"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": {
                    "type": "string",
                    "description": "用户名"
                  },
                  "password": {
                    "type": "string",
                    "description": "密码"
                  }
                },
                "required": ["username", "password"]
              },
              "example": {
                "username": "zhangsan",
                "password": "123456"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "登录成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": { "type": "integer" },
                    "msg": { "type": "string" },
                    "data": { "type": "string" }
                  }
                },
                "example": {
                  "code": 200,
                  "msg": "success",
                  "data": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                }
              }
            }
          },
          "400": { "description": "参数错误" },
          "401": { "description": "用户名或密码错误" }
        }
      },
      "delete": {
        "summary": "删除用户会话（登出）",
        "description": "用户登出，销毁当前会话",
        "tags": ["认证"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "登出成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": { "type": "integer" },
                    "msg": { "type": "string" },
                    "data": { "type": "null" }
                  }
                },
                "example": {
                  "code": 200,
                  "msg": "success",
                  "data": null
                }
              }
            }
          },
          "401": { "description": "未认证" }
        }
      }
    },
    "/api/v1/users": {
      "post": {
        "summary": "创建用户（注册）",
        "description": "新用户注册账号",
        "tags": ["用户"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": {
                    "type": "string",
                    "minLength": 3,
                    "maxLength": 20,
                    "description": "用户名（要求唯一）"
                  },
                  "password": {
                    "type": "string",
                    "minLength": 6,
                    "maxLength": 20,
                    "description": "密码"
                  },
                  "phone": {
                    "type": "string",
                    "description": "手机号"
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "邮箱"
                  }
                },
                "required": ["username", "password"]
              },
              "example": {
                "username": "zhangsan",
                "password": "123456",
                "phone": "13800138000",
                "email": "zhangsan@example.com"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "注册成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": { "type": "integer" },
                    "msg": { "type": "string" },
                    "data": { "type": "null" }
                  }
                },
                "example": {
                  "code": 200,
                  "msg": "success",
                  "data": null
                }
              }
            }
          },
          "400": { "description": "参数错误" },
          "409": { "description": "用户名已存在" }
        }
      }
    },
    "/api/v1/users/me": {
      "get": {
        "summary": "获取当前登录用户信息",
        "description": "获取当前登录用户的详细信息",
        "tags": ["用户"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": { "type": "integer" },
                    "msg": { "type": "string" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "integer" },
                        "username": { "type": "string" },
                        "nickname": { "type": "string" },
                        "avatar": { "type": "string" },
                        "email": { "type": "string" },
                        "phone": { "type": "string" }
                      }
                    }
                  }
                },
                "example": {
                  "code": 200,
                  "msg": "success",
                  "data": {
                    "id": 1,
                    "username": "zhangsan",
                    "nickname": "张三",
                    "avatar": "https://example.com/avatar.jpg",
                    "email": "zhangsan@example.com",
                    "phone": "13800138000"
                  }
                }
              }
            }
          },
          "401": { "description": "未认证" }
        }
      },
      "put": {
        "summary": "更新当前用户信息",
        "description": "更新当前登录用户的信息",
        "tags": ["用户"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nickname": { "type": "string" },
                  "avatar": { "type": "string" },
                  "email": { "type": "string" },
                  "phone": { "type": "string" }
                }
              },
              "example": {
                "nickname": "张三",
                "avatar": "https://example.com/new-avatar.jpg"
              }
            }
          }
        },
        "responses": {
          "200": { "description": "更新成功" },
          "401": { "description": "未认证" }
        }
      }
    },
    "/api/v1/users/{id}": {
      "get": {
        "summary": "获取指定用户信息",
        "description": "根据用户 ID 获取用户详细信息",
        "tags": ["用户"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "用户 ID",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "成功" },
          "404": { "description": "用户不存在" }
        }
      }
    },
    "/api/v1/products": {
      "get": {
        "summary": "分页获取商品列表",
        "tags": ["商品"],
        "parameters": [
          {
            "name": "pageNum",
            "in": "query",
            "description": "当前页码",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "每页数量",
            "schema": { "type": "integer", "default": 10 }
          },
          {
            "name": "keyword",
            "in": "query",
            "description": "搜索关键字",
            "schema": { "type": "string" }
          },
          {
            "name": "categoryId",
            "in": "query",
            "description": "分类 ID",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "成功" }
        }
      }
    },
    "/api/v1/products/{id}": {
      "get": {
        "summary": "获取商品详情",
        "tags": ["商品"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "商品 ID",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "成功" },
          "404": { "description": "商品不存在" }
        }
      }
    },
    "/api/v1/carts": {
      "get": {
        "summary": "获取购物车列表",
        "tags": ["购物车"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "成功" },
          "401": { "description": "未认证" }
        }
      },
      "post": {
        "summary": "添加商品到购物车",
        "tags": ["购物车"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "成功" },
          "401": { "description": "未认证" }
        }
      },
      "delete": {
        "summary": "清空购物车",
        "tags": ["购物车"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "成功" },
          "401": { "description": "未认证" }
        }
      }
    },
    "/api/v1/carts/{id}": {
      "put": {
        "summary": "更新购物车商品数量",
        "tags": ["购物车"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "购物车项 ID",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "成功" },
          "404": { "description": "购物车项不存在" }
        }
      },
      "delete": {
        "summary": "删除购物车商品",
        "tags": ["购物车"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "购物车项 ID",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "成功" },
          "404": { "description": "购物车项不存在" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [{ "bearerAuth": [] }]
}
